[Unit]
Description=Team 1038 CAD Viewer
After=multi-user.target
Wants=multi-user.target

[Service]
Type=simple
WorkingDirectory=/mnt/1038Pit/PitDisplay/autodesk-viewer
ExecStart=/bin/bash -c 'until [ -f /mnt/1038Pit/PitDisplay/index.html ]; do sleep 2; done; exec /usr/bin/python3 -m http.server 8080'
Restart=always
RestartSec=3

[Install]
WantedBy=default.target